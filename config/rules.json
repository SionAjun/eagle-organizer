{
  "version": "2.2.0",
  "naming_conventions": {
    "格-": "尽量用中文官方译名，无法翻译或无通用译名时才保留原文。例：格-星空（Starfield）、格-喷射战士（Splatoon）、格-毁灭战士（DOOM）、格-完美音浪（Hi-Fi Rush）、格-银翼杀手（Blade Runner）"
  },
  "incompatible_prefixes": {
    "类-UI": [
      "镜-",
      "光-",
      "氛-",
      "场-",
      "构-",
      "件-",
      "载-",
      "域-"
    ],
    "类-排版": [
      "镜-",
      "光-",
      "氛-",
      "场-",
      "件-",
      "载-",
      "域-"
    ],
    "类-教程": [
      "氛-"
    ],
    "类-拆解图": [
      "氛-",
      "光-"
    ],
    "类-像素画": [
      "材-"
    ]
  },
  "ge_skip_when_contains": [
    "类-实景参考",
    "类-照片",
    "类-摄影",
    "类-游戏截图"
  ],
  "ge_synonyms": {
    "黑魂": "格-魂系",
    "魂like": "格-魂系",
    "Souls": "格-魂系"
  }
}