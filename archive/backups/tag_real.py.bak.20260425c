REPLACEMENT_WHITELIST = {
    "光-柔光": [
        "光-白天", "光-黄昏", "光-黎明", "光-夜晚", "光-暗光",
        "光-顶光", "光-侧光", "光-底光", "光-伦勃朗光", "光-蝴蝶光",
        "光-边缘光", "光-轮廓光", "光-三点布光", "光-高反差",
